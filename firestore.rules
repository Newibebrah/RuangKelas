rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isMember(roomId) {
      return exists(/databases/$(database)/documents/rooms/$(roomId)/members/$(request.auth.uid));
    }

    function isAdmin(roomId) {
      return get(/databases/$(database)/documents/rooms/$(roomId)/members/$(request.auth.uid)).data.role == 'admin';
    }

    // ===== ROOMS =====
    match /rooms/{roomId} {
      allow read: if isAuth();
      allow write: if isAuth();

      match /members/{userId} {
        allow read: if isAuth();
        allow write: if request.auth.uid == userId || isAdmin(roomId);
      }
    }

    // ===== ROOM DATA (hanya member yg bisa akses) =====
    function roomDataRead(roomId) {
      return isAuth() && isMember(roomId);
    }

    function roomDataWrite(roomId) {
      return isAuth() && isAdmin(roomId);
    }

    match /kas/{docId} {
      allow read: if roomDataRead(resource.data.roomId);
      allow create: if roomDataWrite(request.resource.data.roomId);
      allow update, delete: if roomDataWrite(resource.data.roomId);
    }

    match /transactions/{docId} {
      allow read: if roomDataRead(resource.data.roomId);
      allow create: if roomDataWrite(request.resource.data.roomId);
      allow update, delete: if roomDataWrite(resource.data.roomId);
    }

    match /bills/{docId} {
      allow read: if roomDataRead(resource.data.roomId);
      allow create: if roomDataWrite(request.resource.data.roomId);
      allow update, delete: if roomDataWrite(resource.data.roomId);
    }

    match /paymentPeriods/{docId} {
      allow read: if roomDataRead(resource.data.roomId);
      allow write: if roomDataWrite(resource.data.roomId);
    }

    match /payments/{docId} {
      allow read: if roomDataRead(resource.data.roomId);
      allow write: if roomDataWrite(resource.data.roomId);
    }

    match /tugas/{docId} {
      allow read: if roomDataRead(resource.data.roomId);
      allow create: if roomDataWrite(request.resource.data.roomId);
      allow update, delete: if roomDataWrite(resource.data.roomId);

      match /submissions/{subId} {
        allow read: if isAuth();
        allow create: if isAuth() && request.auth.uid == request.resource.data.userId;
        allow update: if isAuth() && (
          request.auth.uid == resource.data.userId ||
          roomDataWrite(resource.data.roomId)
        );
        allow delete: if roomDataWrite(resource.data.roomId);
      }
    }

    match /pengurus/{docId} {
      allow read: if roomDataRead(resource.data.roomId);
      allow write: if roomDataWrite(resource.data.roomId);
    }

    match /subjectPJ/{docId} {
      allow read: if roomDataRead(resource.data.roomId);
      allow write: if roomDataWrite(resource.data.roomId);
    }

    match /deployments/{docId} {
      allow read: if roomDataRead(resource.data.roomId);
      allow create: if roomDataWrite(request.resource.data.roomId);
      allow update, delete: if roomDataWrite(resource.data.roomId);
    }

    // ===== USER DATA =====
    match /users/{userId} {
      allow read: if isAuth();
      allow write: if request.auth.uid == userId;
    }

    match /notifications/{userId}/items/{notifId} {
      allow read, write: if request.auth.uid == userId;
    }
  }
}
